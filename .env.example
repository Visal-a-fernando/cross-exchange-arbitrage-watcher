# ============================================================
# Watcher Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# The bot runs in PUBLIC WebSocket mode (no keys required).
# API keys are optional and only needed for balance polling.
# ============================================================

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Bybit ---
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- Telegram Alerts (Phase 2) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Deployment Region (informational label only) ---
# Options: "Perth - DEBUG" | "Tokyo ap-northeast-1"
DEPLOY_REGION=Perth - DEBUG

# --- AWS Tokyo latency tip ---
# When deploying to AWS Tokyo (ap-northeast-1), set this env var
# in your systemd unit or .bashrc to reduce DNS lookup overhead:
#   export AIOHTTP_CLIENT_DNS_CACHE=false
